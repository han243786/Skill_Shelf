{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://skill-shelf.local/topological-modular-governance/topology-task-card.schema.json",
  "title": "Topology Task Card",
  "type": "object",
  "required": [
    "work_mode",
    "reason",
    "allowed_scope",
    "parent_node",
    "changed_edges",
    "gates",
    "exit_gate",
    "rollback"
  ],
  "additionalProperties": false,
  "properties": {
    "work_mode": {
      "type": "string",
      "enum": ["refactor", "advance", "aspect_polish", "doc_debt_cleanup"]
    },
    "reason": { "type": "string", "minLength": 1 },
    "allowed_scope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "parent_node": { "type": "string", "minLength": 1 },
    "affected_child_nodes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "changed_edges": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "public_methods_or_ports": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "state_or_side_effects": {
      "type": "string",
      "enum": ["none", "read_only", "state_changed", "persistence_changed", "external_io_changed", "security_changed"]
    },
    "full_tree_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "module_tree_nodes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "legacy_paths": {
      "type": "string",
      "enum": ["none", "archived", "retired", "debt_open"]
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "exit_gate": { "type": "string", "minLength": 1 },
    "rollback": { "type": "string", "minLength": 1 }
  }
}
