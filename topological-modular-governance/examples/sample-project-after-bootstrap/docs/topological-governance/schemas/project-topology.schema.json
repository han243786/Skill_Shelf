{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://skill-shelf.local/topological-modular-governance/project-topology.schema.json",
  "title": "Project Topology",
  "type": "object",
  "required": ["version", "top_level_nodes", "parent_child_rule"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "top_level_nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["node", "purpose", "owner", "main_paths", "status"],
        "additionalProperties": false,
        "properties": {
          "node": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "main_paths": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "status": {
            "type": "string",
            "enum": ["candidate", "active", "closed", "deprecated", "archived"]
          }
        }
      }
    },
    "parent_child_rule": {
      "type": "string",
      "enum": ["parent_facade_required", "contract_or_adapter_required"]
    },
    "hot_assets": {
      "type": "array",
      "items": { "type": "string" }
    },
    "old_path_debt": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "status"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["none", "archived", "retired", "debt_open"]
          },
          "plan": { "type": "string" }
        }
      }
    }
  }
}
