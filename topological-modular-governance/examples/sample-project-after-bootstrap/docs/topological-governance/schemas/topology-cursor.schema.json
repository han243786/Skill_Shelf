{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://skill-shelf.local/topological-modular-governance/topology-cursor.schema.json",
  "title": "Topology Cursor",
  "type": "object",
  "required": [
    "cursor_id",
    "status",
    "work_mode_stack",
    "topology_slice",
    "allowed_workset",
    "forbidden_operations",
    "gates",
    "closeout_required",
    "next_action"
  ],
  "additionalProperties": false,
  "properties": {
    "cursor_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["active", "blocked", "closed", "superseded"]
    },
    "work_mode_stack": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["mode", "step"],
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["refactor", "advance", "aspect_polish", "doc_debt_cleanup"]
          },
          "step": { "type": "string", "minLength": 1 }
        }
      }
    },
    "topology_slice": {
      "type": "object",
      "required": ["parent_node", "child_nodes", "changed_edges"],
      "properties": {
        "parent_node": { "type": "string", "minLength": 1 },
        "child_nodes": { "type": "array", "items": { "type": "string" } },
        "changed_edges": { "type": "array", "items": { "type": "string" } }
      }
    },
    "allowed_workset": {
      "type": "object",
      "required": ["editable_files", "readonly_files"],
      "properties": {
        "editable_files": { "type": "array", "items": { "type": "string" } },
        "readonly_files": { "type": "array", "items": { "type": "string" } }
      }
    },
    "forbidden_operations": { "type": "array", "items": { "type": "string" } },
    "gates": { "type": "array", "items": { "type": "string" } },
    "closeout_required": { "type": "boolean" },
    "next_action": { "type": "string", "minLength": 1 },
    "handoff_notes": { "type": "string" }
  }
}
